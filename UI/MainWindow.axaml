<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NodeKit.UI.MainWindow"
        Title="NodeKit — Tool Authoring Console"
        Width="1280" Height="900"
        WindowStartupLocation="CenterScreen">

  <DockPanel>

    <!-- 상단 타이틀바 -->
    <Border DockPanel.Dock="Top" Background="#1c1b2b" Padding="16,10">
      <TextBlock Text="NodeKit — Tool Authoring Console"
                 FontSize="15" FontWeight="SemiBold" Foreground="White"/>
    </Border>

    <!-- 좌측 네비게이션 -->
    <Border DockPanel.Dock="Left" Width="180" Background="#16151f" Padding="8">
      <StackPanel Spacing="4">
        <TextBlock Text="MENU" FontSize="10" Foreground="#888" Margin="8,0,0,8"/>
        <Button Name="NavAuthoringButton" HorizontalAlignment="Stretch"
                Background="Transparent" Foreground="White" Padding="10,8">
          Tool 정의
        </Button>
        <Button Name="NavToolListButton" HorizontalAlignment="Stretch"
                Background="Transparent" Foreground="White" Padding="10,8">
          등록된 Tools
        </Button>
        <Button Name="NavDataListButton" HorizontalAlignment="Stretch"
                Background="Transparent" Foreground="White" Padding="10,8">
          등록된 Data
        </Button>
        <Button Name="NavPolicyButton" HorizontalAlignment="Stretch"
                Background="Transparent" Foreground="White" Padding="10,8">
          정책 관리
        </Button>
        <Separator Background="#333" Height="1" Margin="8,4"/>
        <Button Name="NavSettingsButton" HorizontalAlignment="Stretch"
                Background="Transparent" Foreground="#aaa" Padding="10,8">
          ⚙ 서버 설정
        </Button>
      </StackPanel>
    </Border>

    <!-- 메인 컨텐츠 -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- 컨텐츠 패널 -->
      <Border Grid.Row="0" Background="#12111a">
        <Grid>

        <!-- Tool 정의 패널 -->
        <ScrollViewer Name="AuthoringPanel" Padding="20">
          <StackPanel Spacing="14" MaxWidth="820">

            <TextBlock Text="Tool 정의" FontSize="18" FontWeight="SemiBold" Foreground="White"/>

            <!-- 이름 + 버전 -->
            <Grid ColumnDefinitions="*,12,160">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Tool 이름" Foreground="#aaa" FontSize="12"/>
                <TextBox Name="ToolNameBox" PlaceholderText="예: bwa-mem" Background="#1e1d2e" Foreground="White"
                         BorderBrush="#333" Padding="8"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="버전" Foreground="#aaa" FontSize="12"/>
                <TextBox Name="ToolVersionBox" PlaceholderText="예: 0.7.17" Background="#1e1d2e" Foreground="White"
                         BorderBrush="#333" Padding="8"/>
              </StackPanel>
            </Grid>

            <!-- 이미지 URI -->
            <StackPanel Spacing="4">
              <TextBlock Text="컨테이너 이미지 URI (digest 포함 필수)" Foreground="#aaa" FontSize="12"/>
              <TextBox Name="ImageUriBox"
                       PlaceholderText="예: registry.example.com/bwa-mem:0.7.17@sha256:abc123..."
                       Background="#1e1d2e" Foreground="White" BorderBrush="#333" Padding="8"/>
            </StackPanel>

            <!-- Dockerfile -->
            <StackPanel Spacing="4">
              <TextBlock Text="Dockerfile" Foreground="#aaa" FontSize="12"/>
              <TextBox Name="DockerfileBox" AcceptsReturn="True" Height="120"
                       PlaceholderText="FROM ubuntu:22.04 AS builder&#10;RUN apt-get install -y ..."
                       Background="#1e1d2e" Foreground="White" BorderBrush="#333"
                       Padding="8" FontFamily="Monospace"/>
            </StackPanel>

            <!-- Script -->
            <StackPanel Spacing="4">
              <TextBlock Text="실행 스크립트" Foreground="#aaa" FontSize="12"/>
              <TextBox Name="ScriptBox" AcceptsReturn="True" Height="60"
                       Background="#1e1d2e" Foreground="White" BorderBrush="#333"
                       Padding="8" FontFamily="Monospace"/>
            </StackPanel>

            <!-- 런타임 커맨드 (CMD 오버라이드) -->
            <StackPanel Spacing="4">
              <TextBlock Text="런타임 커맨드 오버라이드 (선택, Dockerfile CMD 대체)" Foreground="#aaa" FontSize="12"/>
              <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#666"
                         Text="Dockerfile ENTRYPOINT가 아닌 CMD를 K8s Job 제출 시 교체합니다. podbridge5 executor 패턴 기준. JSON 배열 형식 입력."/>
              <TextBox Name="CommandBox" FontFamily="Monospace"
                       PlaceholderText='예: ["/bin/sh", "-c", "/app/executor.sh"]'
                       Background="#1e1d2e" Foreground="White" BorderBrush="#333" Padding="8"/>
            </StackPanel>

            <!-- I/O 포트 선언 -->
            <Grid ColumnDefinitions="*,16,*">

              <!-- Inputs -->
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Inputs" Foreground="#aaa" FontSize="12" FontWeight="SemiBold"/>
                <!-- 헤더 -->
                <Grid ColumnDefinitions="2*,4,1.5*,4,1.2*,4,60,4,Auto">
                  <TextBlock Grid.Column="0" Text="이름" Foreground="#666" FontSize="10"/>
                  <TextBlock Grid.Column="2" Text="역할(role)" Foreground="#666" FontSize="10"/>
                  <TextBlock Grid.Column="4" Text="형식(format)" Foreground="#666" FontSize="10"/>
                  <TextBlock Grid.Column="6" Text="shape" Foreground="#666" FontSize="10"/>
                </Grid>
                <StackPanel Name="InputRowsPanel" Spacing="4"/>
                <Button Name="AddInputButton"
                        Background="#1e1d2e" Foreground="#4a9eff"
                        BorderBrush="#333" Padding="6,4"
                        HorizontalAlignment="Left">
                  + Input 추가
                </Button>
              </StackPanel>

              <!-- Outputs -->
              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="Outputs" Foreground="#aaa" FontSize="12" FontWeight="SemiBold"/>
                <!-- 헤더 -->
                <Grid ColumnDefinitions="2*,4,1.5*,4,1.2*,4,60,4,60,4,Auto">
                  <TextBlock Grid.Column="0" Text="이름" Foreground="#666" FontSize="10"/>
                  <TextBlock Grid.Column="2" Text="역할(role)" Foreground="#666" FontSize="10"/>
                  <TextBlock Grid.Column="4" Text="형식(format)" Foreground="#666" FontSize="10"/>
                  <TextBlock Grid.Column="6" Text="shape" Foreground="#666" FontSize="10"/>
                  <TextBlock Grid.Column="8" Text="class" Foreground="#666" FontSize="10"/>
                </Grid>
                <StackPanel Name="OutputRowsPanel" Spacing="4"/>
                <Button Name="AddOutputButton"
                        Background="#1e1d2e" Foreground="#4a9eff"
                        BorderBrush="#333" Padding="6,4"
                        HorizontalAlignment="Left">
                  + Output 추가
                </Button>
              </StackPanel>

            </Grid>

            <!-- 환경 스펙 -->
            <StackPanel Spacing="4">
              <TextBlock Text="환경 스펙 파일 (conda yml / requirements.txt, 선택)" Foreground="#aaa" FontSize="12"/>
              <TextBox Name="EnvSpecBox" AcceptsReturn="True" Height="80"
                       Background="#1e1d2e" Foreground="White" BorderBrush="#333"
                       Padding="8" FontFamily="Monospace"/>
            </StackPanel>

            <!-- UI 팔레트 표시 정보 (display 섹션) -->
            <Border Background="#0f1020" BorderBrush="#2a2a40" BorderThickness="1" CornerRadius="4" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Text="UI 팔레트 표시 정보 (display)" Foreground="#7a8ab8" FontSize="12" FontWeight="SemiBold"/>

                <!-- 레이블 + 카테고리 -->
                <Grid ColumnDefinitions="*,12,160">
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="레이블 (UI 카드 제목)" Foreground="#aaa" FontSize="11"/>
                    <TextBox Name="DisplayLabelBox" PlaceholderText="예: BWA-MEM 0.7.17"
                             Background="#1e1d2e" Foreground="White" BorderBrush="#2a2a40" Padding="7"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="카테고리" Foreground="#aaa" FontSize="11"/>
                    <TextBox Name="DisplayCategoryBox" PlaceholderText="예: Alignment"
                             Background="#1e1d2e" Foreground="White" BorderBrush="#2a2a40" Padding="7"/>
                  </StackPanel>
                </Grid>

                <!-- 설명 -->
                <StackPanel Spacing="4">
                  <TextBlock Text="설명 (툴팁)" Foreground="#aaa" FontSize="11"/>
                  <TextBox Name="DisplayDescriptionBox"
                           PlaceholderText="예: paired-end FASTQ → coordinate-sorted BAM"
                           Background="#1e1d2e" Foreground="White" BorderBrush="#2a2a40" Padding="7"/>
                </StackPanel>

                <!-- 태그 -->
                <StackPanel Spacing="4">
                  <TextBlock Text="태그 (쉼표 구분)" Foreground="#aaa" FontSize="11"/>
                  <TextBox Name="DisplayTagsBox" PlaceholderText="예: dna, alignment, bwa, short-read"
                           Background="#1e1d2e" Foreground="White" BorderBrush="#2a2a40" Padding="7"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- L1 검증 결과 -->
            <Border Name="ValidationResultPanel" IsVisible="False"
                    Background="#1a1228" BorderBrush="#c0392b" BorderThickness="1" CornerRadius="4" Padding="12">
              <StackPanel Spacing="4">
                <TextBlock Text="L1 검증 결과" FontWeight="SemiBold" Foreground="#e74c3c" FontSize="13"/>
                <ItemsControl Name="ViolationsList">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                      <TextBlock Text="{Binding}" Foreground="#e74c3c" FontSize="12" TextWrapping="Wrap"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Name="ValidationPassPanel" IsVisible="False"
                    Background="#0d1f12" BorderBrush="#27ae60" BorderThickness="1" CornerRadius="4" Padding="12">
              <TextBlock Text="✓ L1 검증 통과" Foreground="#2ecc71" FontSize="13" FontWeight="SemiBold"/>
            </Border>

            <!-- 버튼 행 -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Name="ValidateButton" Padding="16,8" Background="#2c3e88" Foreground="White">
                L1 검증
              </Button>
              <Button Name="SendBuildButton" Padding="16,8" Background="#27ae60" Foreground="White" IsEnabled="False">
                빌드 요청 전송 (NodeVault)
              </Button>
            </StackPanel>

            <!-- 빌드 로그 패널 -->
            <Border Name="BuildLogPanel" IsVisible="False"
                    Background="#0d1018" BorderBrush="#2c3e88" BorderThickness="1" CornerRadius="4" Padding="12">
              <StackPanel Spacing="6">
                <TextBlock Text="빌드 로그" FontWeight="SemiBold" Foreground="#4a9eff" FontSize="13"/>
                <ScrollViewer Name="BuildLogScroll" Height="200">
                  <TextBox Name="BuildLogBox" AcceptsReturn="True" IsReadOnly="True"
                           Background="Transparent" Foreground="#c0c8d8"
                           BorderThickness="0" FontFamily="Monospace" FontSize="11"
                           TextWrapping="Wrap"/>
                </ScrollViewer>
              </StackPanel>
            </Border>

            <!-- 빌드 성공 표시 -->
            <Border Name="BuildSuccessPanel" IsVisible="False"
                    Background="#0d1f12" BorderBrush="#27ae60" BorderThickness="1" CornerRadius="4" Padding="12">
              <StackPanel Spacing="4">
                <TextBlock Text="✓ 빌드 및 등록 완료" Foreground="#2ecc71" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Name="BuildDigestLabel" Foreground="#aaa" FontSize="11" FontFamily="Monospace"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>

        <!-- 등록된 Tools 패널 -->
        <ScrollViewer Name="ToolListPanel" IsVisible="False" Padding="20">
          <StackPanel Spacing="16" MaxWidth="900">

            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="등록된 Tools" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
              <Button Name="RefreshToolListButton" Grid.Column="1"
                      Background="#2c3e88" Foreground="White" Padding="12,6">
                새로 고침
              </Button>
            </Grid>

            <Border Name="ToolListEmptyPanel" IsVisible="True"
                    Background="#1e1d2e" BorderBrush="#333" BorderThickness="1" CornerRadius="4" Padding="16">
              <TextBlock Text="등록된 툴이 없습니다." Foreground="#666" FontSize="13"/>
            </Border>

            <ItemsControl Name="ToolListItems">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <Border Background="#1e1d2e" BorderBrush="#333" BorderThickness="1"
                          CornerRadius="4" Padding="12" Margin="0,0,0,6">
                    <TextBlock Text="{Binding}" Foreground="#c0c8d8" FontFamily="Monospace"
                               FontSize="12" TextWrapping="Wrap"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </ScrollViewer>

        <!-- 등록된 Data 패널 -->
        <ScrollViewer Name="DataListPanel" IsVisible="False" Padding="20">
          <StackPanel Spacing="16" MaxWidth="900">

            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="등록된 Data" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
              <Button Name="RefreshDataListButton" Grid.Column="1"
                      Background="#2c3e88" Foreground="White" Padding="12,6">
                새로 고침
              </Button>
            </Grid>

            <Border Name="DataListEmptyPanel" IsVisible="True"
                    Background="#1e1d2e" BorderBrush="#333" BorderThickness="1" CornerRadius="4" Padding="16">
              <TextBlock Text="등록된 참조 데이터가 없습니다." Foreground="#666" FontSize="13"/>
            </Border>

            <ItemsControl Name="DataListItems">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <Border Background="#1e1d2e" BorderBrush="#333" BorderThickness="1"
                          CornerRadius="4" Padding="12" Margin="0,0,0,6">
                    <TextBlock Text="{Binding}" Foreground="#c0c8d8" FontFamily="Monospace"
                               FontSize="12" TextWrapping="Wrap"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </ScrollViewer>

        <!-- 정책 관리 패널 -->
        <ScrollViewer Name="PolicyPanel" IsVisible="False" Padding="20">
          <StackPanel Spacing="16" MaxWidth="720">

            <TextBlock Text="정책 관리" FontSize="18" FontWeight="SemiBold" Foreground="White"/>

            <Border Background="#1e1d2e" BorderBrush="#333" BorderThickness="1" CornerRadius="4" Padding="12">
              <StackPanel Spacing="4">
                <TextBlock Text="현재 번들 버전" Foreground="#aaa" FontSize="11"/>
                <TextBlock Name="PolicyBundleVersionLabel" Foreground="White" FontFamily="Monospace" FontSize="12"
                           Text="(조회 전)"/>
              </StackPanel>
            </Border>

            <ItemsControl Name="PolicyListItems">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <Border Background="#1e1d2e" BorderBrush="#333" BorderThickness="1"
                          CornerRadius="4" Padding="12" Margin="0,0,0,6">
                    <TextBlock Text="{Binding}" Foreground="#c0c8d8" FontSize="12" TextWrapping="Wrap"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Name="RefreshPolicyListButton" Background="#2c3e88" Foreground="White" Padding="12,8">
                목록 새로 고침
              </Button>
              <Button Name="ReloadBundleButton" Background="#7d3c98" Foreground="White" Padding="12,8">
                번들 갱신 (WasmPolicyChecker 재로드)
              </Button>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>

        <!-- 서버 설정 패널 -->
        <ScrollViewer Name="SettingsPanel" IsVisible="False" Padding="20">
          <StackPanel Spacing="16" MaxWidth="620">

            <TextBlock Text="서버 연결 설정" FontSize="18" FontWeight="SemiBold" Foreground="White"/>

            <!-- 주소 입력 -->
            <Border Background="#1e1d2e" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="16">
              <StackPanel Spacing="12">
                <TextBlock Text="연결 주소" FontSize="13" FontWeight="SemiBold" Foreground="#4a9eff"/>

                <StackPanel Spacing="4">
                  <TextBlock Text="NodeVault 주소 (gRPC — 빌드 / 정책 서비스)" Foreground="#aaa" FontSize="12"/>
                  <TextBox Name="SettingsNodeVaultAddressBox"
                           PlaceholderText="http://host:50051"
                           Background="#12111a" Foreground="White" BorderBrush="#555" Padding="8"/>
                </StackPanel>

                <StackPanel Spacing="4">
                  <TextBlock Text="Catalog 주소 (REST — Tool / Data 목록 조회)" Foreground="#aaa" FontSize="12"/>
                  <TextBox Name="SettingsCatalogAddressBox"
                           PlaceholderText="http://host:8080"
                           Background="#12111a" Foreground="White" BorderBrush="#555" Padding="8"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- 저장 버튼 -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Name="SaveSettingsButton" Padding="16,8" Background="#27ae60" Foreground="White">
                저장
              </Button>
              <Button Name="ResetSettingsButton" Padding="16,8" Background="#555" Foreground="#ccc">
                기본값으로 초기화
              </Button>
            </StackPanel>

            <!-- 저장 완료 알림 -->
            <Border Name="SettingsSavedPanel" IsVisible="False"
                    Background="#0d1f12" BorderBrush="#27ae60" BorderThickness="1" CornerRadius="4" Padding="12">
              <TextBlock Text="✓ 설정이 저장되었습니다." Foreground="#2ecc71" FontSize="13"/>
            </Border>

            <!-- 설정 파일 경로 -->
            <Border Background="#0d0c18" BorderBrush="#2a2a3a" BorderThickness="1" CornerRadius="4" Padding="12">
              <StackPanel Spacing="4">
                <TextBlock Text="설정 파일 경로" Foreground="#666" FontSize="11"/>
                <TextBlock Name="SettingsFilePathLabel" Foreground="#555" FontSize="11"
                           FontFamily="Monospace" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>

        </Grid>
      </Border>

      <!-- 하단 상태바 -->
      <Border Grid.Row="1" Background="#0d0c18" Padding="16,6">
        <TextBlock Name="StatusBar" Text="준비" Foreground="#666" FontSize="11"/>
      </Border>

    </Grid>

  </DockPanel>

</Window>
