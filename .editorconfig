# ═══════════════════════════════════════════════════════════════
# 🚨 ERROR 격상 규칙 — Go처럼 타협 없는 환경
#
# 원칙: 현재 코드베이스가 이미 준수하는 규칙 + 버그를 직접 유발하는 규칙만 Error로.
# 337개 SA* 경고는 점진적 감소 목표 (DEC-005) — 일괄 Error 지양.
# ═══════════════════════════════════════════════════════════════

# ── Go 핵심 원칙 1: 미사용 코드 금지 ─────────────────────────
# Go는 미사용 변수/임포트를 컴파일 에러로 처리한다.
dotnet_diagnostic.IDE0059.severity = error   # 불필요한 할당 (값이 사용되지 않음)
dotnet_diagnostic.IDE0060.severity = error   # 사용되지 않는 매개변수
dotnet_diagnostic.CS0168.severity  = error   # 변수가 선언됐지만 사용되지 않음
dotnet_diagnostic.CS0219.severity  = error   # 값이 할당됐지만 사용되지 않음

# ── Go 핵심 원칙 2: 명시적 Null 안전성 ──────────────────────
# Go는 nil 역참조를 런타임 패닉으로 처리한다. C#은 컴파일 타임에 잡아야 한다.
dotnet_diagnostic.CS8600.severity  = error   # null을 non-nullable에 할당
dotnet_diagnostic.CS8601.severity  = error   # null 가능한 값을 참조 타입에 할당
dotnet_diagnostic.CS8602.severity  = error   # null 가능한 참조 역참조
dotnet_diagnostic.CS8603.severity  = error   # null 가능한 값 반환
dotnet_diagnostic.CS8604.severity  = error   # null 가능한 값을 인수로 전달
dotnet_diagnostic.CS8618.severity  = error   # non-nullable 필드가 초기화되지 않음
dotnet_diagnostic.CS8625.severity  = error   # null 리터럴을 non-nullable에 전달

# ── Go 핵심 원칙 3: 명시적 접근 한정자 ──────────────────────
# Go는 대소문자로 가시성을 명시한다. C#도 명시적이어야 한다.
dotnet_diagnostic.SA1400.severity  = error   # 접근 한정자 반드시 명시

# ── 안전 코딩: 중괄호 생략 금지 ─────────────────────────────
# 중괄호 생략은 Heartbleed 같은 버그의 원인이다.
dotnet_diagnostic.SA1503.severity  = error   # if/for/while 중괄호 생략 금지

# ── 코드 위생: 빈 구문 금지 ─────────────────────────────────
dotnet_diagnostic.SA1106.severity  = error   # 빈 구문(;) 금지

# ── 네이밍: private 필드 _camelCase 강제 (Error) ─────────────
dotnet_naming_rule.private_fields_should_be_camel_case.severity = error

# ── 타입 키워드: int/string 사용 강제 (Int32/String 금지) ────
dotnet_style_predefined_type_for_locals_parameters_members = true:error
dotnet_style_predefined_type_for_member_access             = true:error
