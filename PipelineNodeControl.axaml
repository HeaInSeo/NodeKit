<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:NodeKit"
        x:CompileBindings="True">

  <Style Selector="local|PipelineNodeControl">
    <Setter Property="Width" Value="200" />
    <Setter Property="Height" Value="80" />
    <Setter Property="Template">
      <ControlTemplate>
        <Grid>
          <!-- 노드 본체 -->
          <Border Background="#1c1b2b"
                  CornerRadius="4"
                  BorderBrush="#5a5a8a"
                  BorderThickness="1">
            <Grid RowDefinitions="Auto,*">
              <!-- 헤더 (노드 이름) -->
              <Border Grid.Row="0"
                      Background="#2e2d4a"
                      CornerRadius="4,4,0,0"
                      Padding="8,4">
                <TextBlock Text="{TemplateBinding NodeName}"
                           Foreground="White"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
              </Border>

              <!-- 포트 영역 -->
              <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="4">
                <!-- 입력 포트 수 -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                  <Ellipse Width="8" Height="8"
                           Fill="#4fc3f7"
                           Margin="0,0,4,0" />
                  <TextBlock Text="{TemplateBinding InputPortCount}"
                             Foreground="#4fc3f7"
                             FontSize="10" />
                </StackPanel>

                <!-- 출력 포트 수 -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                  <TextBlock Text="{TemplateBinding OutputPortCount}"
                             Foreground="#a5d6a7"
                             FontSize="10" />
                  <Ellipse Width="8" Height="8"
                           Fill="#a5d6a7"
                           Margin="4,0,0,0" />
                </StackPanel>
              </Grid>
            </Grid>
          </Border>

          <!-- 선택 테두리 -->
          <Border CornerRadius="4"
                  BorderBrush="#7986cb"
                  BorderThickness="2"
                  IsVisible="{TemplateBinding IsSelected}"
                  IsHitTestVisible="False" />
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>

</Styles>
